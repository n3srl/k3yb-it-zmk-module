config K3YB_KSCAN_GPIO_DEMUX
    bool "k3yb demux kscan driver with active discharge and settle time"
    default y
    depends on DT_HAS_K3YB_KSCAN_GPIO_DEMUX_ENABLED
    select GPIO

config K3YB_LED_MUX
    bool "k3yb status LEDs via CD4052 mux"
    default y
    depends on DT_HAS_K3YB_LED_MUX_ENABLED
    select GPIO

config K3YB_BEHAVIOR_REPEAT
    bool "k3yb auto-repeat wrapper behavior"
    default y
    depends on DT_HAS_K3YB_BEHAVIOR_REPEAT_ENABLED

config K3YB_STATUS_MINIMAL
    bool "bisect: minimal plain-text status refresh"
    default n

config K3YB_STATUS_NO_VOLTAGE
    bool "bisect: full status UI without the voltage sensor read"
    default n

config K3YB_SSD1327
    bool "k3yb SSD1327 grayscale OLED driver (mono over I2C)"
    default y
    depends on DT_HAS_K3YB_SSD1327_ENABLED
    depends on DISPLAY
    select I2C

if K3YB_SSD1327

config K3YB_SSD1327_FB_SIZE
    int
    default 8192
    help
      Shadow framebuffer size in bytes (width/2 * height).

config K3YB_SSD1327_TEST_PATTERN
    bool "Draw a calibration test pattern at init"
    default n
    help
      Draws a geometric fingerprint (top edge, left edge, corner blocks)
      at driver init to calibrate the panel remap from a photo.

endif # K3YB_SSD1327
