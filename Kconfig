config K3YB_KSCAN_GPIO_DEMUX
    bool "k3yb demux kscan driver with active discharge and settle time"
    default y
    depends on DT_HAS_K3YB_KSCAN_GPIO_DEMUX_ENABLED
    select GPIO

config K3YB_LED_MUX
    bool "k3yb status LEDs via CD4052 mux"
    default y
    depends on DT_HAS_K3YB_LED_MUX_ENABLED
    select GPIO

config K3YB_BEHAVIOR_REPEAT
    bool "k3yb auto-repeat wrapper behavior"
    default y
    depends on DT_HAS_K3YB_BEHAVIOR_REPEAT_ENABLED



config K3YB_STATUS_ICONS
    bool "Status screen uses LVGL symbol icons instead of text markers"
    default n
    help
      Replaces the USB/BT/CH text markers and the battery percentage with
      the built-in LV_SYMBOL_* glyphs, all on the top row (battery on the
      right).  Kept behind an option: glyph rendering crashed the display
      thread before the stack/layout fixes, so text-only stays the default.

config K3YB_SSD1327
    bool "k3yb SSD1327 grayscale OLED driver (mono over I2C)"
    default y
    depends on DT_HAS_K3YB_SSD1327_ENABLED
    depends on DISPLAY
    select I2C

config K3YB_SH1107
    bool "k3yb SH1107 mono OLED driver (I2C)"
    default y
    depends on DT_HAS_K3YB_SH1107_ENABLED
    depends on DISPLAY
    select I2C

if K3YB_SH1107

config K3YB_SH1107_FB_SIZE
    int
    default 2048
    help
      Shadow framebuffer size in bytes (width/8 * height).

endif # K3YB_SH1107

if K3YB_SSD1327

config K3YB_SSD1327_FB_SIZE
    int
    default 8192
    help
      Shadow framebuffer size in bytes (width/2 * height).

config K3YB_SSD1327_TEST_PATTERN
    bool "Draw a calibration test pattern at init"
    default n
    help
      Draws a geometric fingerprint (top edge, left edge, corner blocks)
      at driver init to calibrate the panel remap from a photo.

endif # K3YB_SSD1327
