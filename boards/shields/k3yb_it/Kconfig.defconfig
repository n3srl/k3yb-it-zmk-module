if SHIELD_K3YB_IT

config ZMK_KEYBOARD_NAME
    default "k3yb.it"

# OLED display: custom SSD1327 driver (see drivers/display) on I2C
if ZMK_DISPLAY

config I2C
    default y

endif # ZMK_DISPLAY

# LVGL settings for a 128x128 monochrome-driven OLED
if LVGL

config LV_Z_VDB_SIZE
    default 64

config LV_DPI_DEF
    default 148

config LV_Z_BITS_PER_PIXEL
    default 1

choice LV_COLOR_DEPTH
    default LV_COLOR_DEPTH_1
endchoice

endif # LVGL

endif # SHIELD_K3YB_IT
