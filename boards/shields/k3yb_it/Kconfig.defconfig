if SHIELD_K3YB_IT || SHIELD_K3YB_IT_OLED32 || SHIELD_K3YB_IT_OLED128

config ZMK_KEYBOARD_NAME
    default "k3yb.it"

if ZMK_DISPLAY

config I2C
    default y

endif # ZMK_DISPLAY

# LVGL settings for the monochrome-driven OLED variants
if LVGL

config LV_Z_VDB_SIZE
    default 64

config LV_DPI_DEF
    default 148

config LV_Z_BITS_PER_PIXEL
    default 1

choice LV_COLOR_DEPTH
    default LV_COLOR_DEPTH_1
endchoice

endif # LVGL

endif # any k3yb_it variant

# SSD1306 in-tree driver for the 128x32 variant
if SHIELD_K3YB_IT_OLED32 && ZMK_DISPLAY

config SSD1306
    default y

endif
